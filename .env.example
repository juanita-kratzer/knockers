# Firebase Configuration
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY

# Stripe (set to "true" + publishable key to enable payments)
# VITE_STRIPE_ENABLED=true
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# RevenueCat (Apple IAP for verification fee)
# VITE_REVENUECAT_API_KEY=appl_your_key_here

# Set to "true" to bypass identity + fee verification during dev
VITE_SKIP_IDENTITY_VERIFICATION=true

# Uncomment to use Firebase emulators for local dev
# VITE_USE_EMULATORS=true
